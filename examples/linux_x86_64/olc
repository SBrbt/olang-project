#!/usr/bin/env bash
# olc — Linux x86_64 driver: olprep (preprocess) -> bin/olang, kasm, alinker; reads link and kasm presets from examples/linux_x86_64/.
# Intermediate files are kept under <basename>.olc.d/ next to the output ELF (not deleted).
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TOOLCHAIN_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
PLATFORM="$SCRIPT_DIR"
export OLANG_TOOLCHAIN_ROOT="$TOOLCHAIN_ROOT"

OLPREP="$TOOLCHAIN_ROOT/bin/olprep"
OLANG="$TOOLCHAIN_ROOT/bin/olang"
KASM="$TOOLCHAIN_ROOT/bin/kasm"
ALINKER="$TOOLCHAIN_ROOT/bin/alinker"

EXE_JSON="$PLATFORM/link/linux_elf_exe.json"
KRT_KASM="$PLATFORM/asm/runtime/krt.kasm"
OLRT_KASM="$PLATFORM/asm/runtime/olrt.kasm"
POSIX_KASM="$PLATFORM/asm/lib/libposix.kasm"

MAX_SRC=48

usage() {
  cat <<'EOF'
usage: olc -o <out.elf> <a.ol> [b.ol ...]
       olc -h
  Linux x86_64 ELF: each .ol -> olprep -> .oobj, then link with runtime.
  Preset paths: examples/linux_x86_64/{link/linux_elf_exe.json, asm/**}
  Work directory: <dir(out.elf)>/<basename(out.elf)>.olc.d/ (pp*.ol, u*.oobj, runtime .oobj)
  Requires: make to generate bin/olprep, olang, kasm, alinker.
EOF
}

for x in "$OLPREP" "$OLANG" "$KASM" "$ALINKER"; do
  if [[ ! -x "$x" ]]; then
    echo "olc: missing $x (run make from repo root)" >&2
    exit 1
  fi
done

out_elf=
sources=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h | --help)
      usage
      exit 0
      ;;
    -o)
      if [[ $# -lt 2 ]]; then
        echo "olc: missing value for -o" >&2
        usage >&2
        exit 2
      fi
      out_elf="$2"
      shift 2
      ;;
    -*)
      echo "olc: unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
    *)
      if [[ ${#sources[@]} -ge MAX_SRC ]]; then
        echo "olc: too many .ol sources (max $MAX_SRC)" >&2
        exit 2
      fi
      sources+=("$1")
      shift
      ;;
  esac
done

if [[ -z "${out_elf:-}" ]] || [[ ${#sources[@]} -eq 0 ]]; then
  usage >&2
  exit 2
fi

out_dir=$(dirname -- "$out_elf")
out_base=$(basename -- "$out_elf" .elf)
WORKDIR=$(cd "$out_dir" && echo "$(pwd)/${out_base}.olc.d")
mkdir -p "$WORKDIR"

for i in "${!sources[@]}"; do
  "$OLPREP" --in "${sources[$i]}" -o "$WORKDIR/pp${i}.ol" -I "$PLATFORM/include"
  "$OLANG" --target x86_64 --in "$WORKDIR/pp${i}.ol" -o "$WORKDIR/u${i}.oobj"
done

"$KASM" --in "$KRT_KASM" -o "$WORKDIR/krt.oobj"
"$KASM" --in "$OLRT_KASM" -o "$WORKDIR/olrt.oobj"
"$KASM" --in "$POSIX_KASM" -o "$WORKDIR/libposix.oobj"

link_cmd=("$ALINKER" "--script" "$EXE_JSON" "-o" "$out_elf" "--")
for i in "${!sources[@]}"; do
  link_cmd+=("$WORKDIR/u${i}.oobj")
done
link_cmd+=("$WORKDIR/libposix.oobj" "$WORKDIR/krt.oobj" "$WORKDIR/olrt.oobj")
"${link_cmd[@]}"

chmod 0755 "$out_elf" || {
  echo "olc: chmod $out_elf: failed" >&2
  exit 1
}

exit 0
